{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noUncheckedIndexedAccess": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "outDir": "./dist",
        "allowImportingTsExtensions": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts", "src/**/*.stories.ts"]
}
