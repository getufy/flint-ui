  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "test": "NODE_OPTIONS='--no-warnings' vitest run",
    "test:watch": "NODE_OPTIONS='--no-warnings' vitest",
    "cem": "custom-elements-manifest analyze --config custom-elements-manifest.config.mjs",
    "build": "vite build && tsc -p tsconfig.build.json && npm run cem",
    "build:exports": "tsx ../../scripts/build-entries.ts --write-exports",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-coverage": "NODE_OPTIONS='--no-warnings' vitest run --project components --coverage",
    "stryker": "npx stryker run",
    "bench": "vitest bench --config vitest.bench.config.ts",
    "test:snapshots": "NODE_OPTIONS='--no-warnings' vitest run --project components src/__snapshots__/",
    "prepublishOnly": "npm run lint && npm run build"
  },
