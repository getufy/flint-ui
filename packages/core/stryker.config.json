{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.stories.ts",
    "!src/**/*.test.ts",
    "!src/index.ts"
  ],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "disableTypeChecks": "src/**/*.ts"
}
